# Jungle World — Supabase backend config. Copy to `.env` and fill in.
# Without these, the game falls back to the single-player MockBackend.
#
# VITE_-prefixed vars are compiled into the public browser bundle. Only ever
# put PUBLIC values here (the anon key is public by design).

VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# SECRET. NOT VITE_-prefixed on purpose — never exposed to the browser.
# Only for local admin/setup scripts. Never commit a real value.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
